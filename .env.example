TOKEN=discord_bot_token
CLIENT_ID=discord_application_id

# Основной сервер. Старый GUILD_ID также поддерживается для совместимости.
PROD_GUILD_ID=production_discord_server_id
DEV_GUILD_ID=development_discord_server_id
# GUILD_ID=production_discord_server_id

TELEGRAM_BOT_TOKEN=
DATABASE_PATH=/data/database.sqlite
BACKUP_DIR=/data/backups

ACHIEVEMENTS_CHANNEL_ID=
LUCKY_DAY_CHANNEL_ID=
WELCOME_CHANNEL_ID=
LOG_CHANNEL_ID=
BOT_OWNER_ID=
DEVELOPER_ID=
DEV_MODE=false

# Игровые и служебные каналы
QUICK_EVENT_CHANNEL_ID=
RIDDLE_CHANNEL_ID=
GS_CALL_DISCORD_CHANNEL_ID=
RULES_CHANNEL_ID=
ANNOUNCEMENTS_CHANNEL_ID=
# Несколько ID через запятую, например AFK-канал и приватные голосовые.
EXCLUDED_VOICE_CHANNEL_IDS=

# Публичная ссылка, показываемая новым участникам.
TELEGRAM_INVITE_URL=

# Только для ручного одноразового восстановления статистики Quick Event.
# В обычной установке оставьте пустым.
QUICK_EVENT_SEED_USER_ID=
